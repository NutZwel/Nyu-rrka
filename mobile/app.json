{
  "expo": {
    "name": "Nyu'rka",
    "slug": "nyurrrka-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nyurrrka.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.nyurrrka.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      }
    },
    "plugins": [
      "expo-av",
      "expo-asset"
    ]
  }
}
